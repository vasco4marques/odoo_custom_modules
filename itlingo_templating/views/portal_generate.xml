<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Templates are operational records: make generation the primary detail
         experience while keeping management metadata and actions available. -->
    <template id="portal_document_detail_generate"
              inherit_id="itlingo_documents.portal_document_detail_inner"
              name="Template Generation Detail">
        <xpath expr="//div[hasclass('card')][1]" position="attributes">
            <attribute name="t-if">not document.is_template</attribute>
        </xpath>
        <xpath expr="//div[hasclass('card')][1]" position="after">
            <t t-if="document.is_template">
                <div id="generate" class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2 p-3">
                        <div>
                            <h2 class="h5 fw-semibold mb-0"><t t-out="document.name"/></h2>
                            <span class="text-muted small">Template</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span t-if="document.dsl_id" class="badge bg-light text-dark border">
                                <t t-out="document.dsl_id.acronym"/>
                            </span>
                            <span t-attf-class="badge rounded-pill
                                #{'text-bg-secondary' if document.status == 'draft'
                                  else 'text-bg-warning' if document.status == 'in_review'
                                  else 'text-bg-success' if document.status == 'approved'
                                  else 'text-bg-primary' if document.status == 'published'
                                  else 'text-bg-dark'}">
                                <t t-out="dict(document._fields['status'].selection).get(document.status)"/>
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start gap-3 mb-4">
                            <span class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center flex-shrink-0"
                                  style="width: 2.75rem; height: 2.75rem;">
                                <i class="fa fa-cogs fa-lg" aria-hidden="true"/>
                            </span>
                            <div>
                                <h3 class="h5 mb-1">Generate a document</h3>
                                <p class="text-muted mb-0">
                                    Upload a <t t-out="document.template_source_label"/>.
                                    It will be applied to this template and the generated file will download automatically.
                                </p>
                            </div>
                        </div>

                        <div t-if="generation_error" class="alert alert-danger" role="alert">
                            <div><t t-out="generation_error"/></div>
                            <ul t-if="generation_diagnostics" class="mb-0 mt-2">
                                <li t-foreach="generation_diagnostics" t-as="diagnostic">
                                    <t t-if="diagnostic.get('line') is not None">
                                        Line <t t-out="diagnostic['line'] + 1"/>:
                                    </t>
                                    <t t-out="diagnostic.get('message')"/>
                                </li>
                            </ul>
                        </div>

                        <div t-if="template_lint_result"
                             t-attf-class="alert #{'alert-secondary' if template_lint_result.get('skipped') else 'alert-warning' if template_lint_result.get('findings') else 'alert-success'}"
                             role="status">
                            <div t-if="template_lint_result.get('skipped')">
                                Template checking could not be completed.
                                <span t-if="template_lint_result.get('message')" t-out="template_lint_result['message']"/>
                            </div>
                            <div t-elif="not template_lint_result.get('findings')">
                                No Jinja syntax, filter, or test problems were found.
                                <span t-if="not template_lint_result.get('dsl_skipped')">
                                    No known variable, type, or field-name problems were found.
                                </span>
                                <div t-if="template_lint_result.get('dsl_skipped')" class="small mt-2">
                                    DSL variable checking was skipped because the grammar inventory is unavailable.
                                </div>
                            </div>
                            <t t-else="">
                                <div class="fw-semibold">
                                    <span class="badge text-bg-warning me-1" t-out="len(template_lint_result['findings'])"/>
                                    Advisory template finding(s)
                                </div>
                                <div t-foreach="template_lint_result.get('finding_groups', [])" t-as="group"
                                     t-attf-class="mt-2 template-lint-group template-lint-group-#{group['category']}"
                                     t-att-data-category="group['category']">
                                    <div class="small fw-semibold text-uppercase" t-out="group['label']"/>
                                    <ul class="mb-0">
                                        <li t-foreach="group['findings']" t-as="finding">
                                            <span t-if="finding.get('location')"><t t-out="finding['location']"/>: </span>
                                            <t t-out="finding['message']"/>
                                            <span t-if="finding.get('suggestion')">
                                                Did you mean <code t-out="finding['suggestion']"/>?
                                            </span>
                                        </li>
                                    </ul>
                                </div>
                                <div t-if="template_lint_result.get('dsl_skipped')" class="small mt-2">
                                    DSL variable checking was skipped because the grammar inventory is unavailable.
                                </div>
                                <div t-if="template_lint_result.get('degraded')" class="small mt-2">
                                    Only top-level variables could be checked for this file.
                                </div>
                            </t>
                        </div>

                        <div t-if="not document.document_file" class="alert alert-warning mb-0" role="alert">
                            Upload a template file before generating a document.
                        </div>
                        <div t-elif="not document.template_generation_supported" class="alert alert-warning mb-0" role="alert">
                            This DSL needs an active, current, valid published grammar before templates can be generated.
                        </div>
                        <div t-elif="not document.template_format_supported" class="alert alert-warning mb-0" role="alert">
                            The attached template format is not supported for generation.
                        </div>
                        <form t-else="" t-attf-action="#{doc_base_url}/#{document.id}/generate"
                              method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="p-3 p-md-4 border rounded-3 bg-light mb-3">
                                <label class="form-label fw-semibold" for="source_file">
                                    <t t-out="document.template_source_label"/>
                                </label>
                                <input type="file" class="form-control bg-white" id="source_file"
                                       name="source_file" t-att-accept="document.template_source_accept"
                                       required="required"/>
                                <div t-if="document.template_source_accept" class="form-text">
                                    Accepted files:
                                    <t t-out="document.template_source_accept.replace(',', ', ')"/>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-success">
                                <i class="fa fa-cogs me-1" aria-hidden="true"/> Generate and download
                            </button>
                            <button type="submit" formnovalidate="formnovalidate"
                                    t-attf-formaction="#{doc_base_url}/#{document.id}/check"
                                    class="btn btn-outline-secondary ms-1">
                                <i class="fa fa-check-circle me-1" aria-hidden="true"/> Check template
                            </button>
                            <details class="mt-4">
                                <summary class="fw-semibold">Available template variables</summary>
                                <div class="small text-muted mt-2">
                                    <p class="mb-2">
                                        Every DSL provides
                                        <code t-foreach="document.template_variable_groups.get('core', [])"
                                              t-as="variable" class="me-1"><t t-out="variable"/></code>.
                                        Group concepts by grammar type with
                                        <code>by_type['ConceptName']</code>.
                                    </p>
                                    <p t-if="document.template_variable_groups.get('aliases')" class="mb-0">
                                        This DSL also defines friendly aliases:
                                        <code t-foreach="document.template_variable_groups['aliases']"
                                              t-as="variable" class="me-1"><t t-out="variable"/></code>.
                                    </p>
                                    <p t-if="document.dsl_id" class="mt-2 mb-0">
                                        <a t-attf-href="/dsl/#{document.dsl_id.id}/template-reference">
                                            Browse the complete <t t-out="document.dsl_id.acronym"/> Template Reference
                                        </a>
                                        for exact type and field names.
                                    </p>
                                </div>
                            </details>
                        </form>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3 mt-3">
                    <div class="card-header bg-white p-3">
                        <h3 class="h6 fw-semibold mb-0">Template information</h3>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 small">
                            <div class="col-sm-6 col-xl-3">
                                <div class="text-muted">Template file</div>
                                <div class="fw-semibold text-break"><t t-out="document.file_name or 'No file uploaded'"/></div>
                            </div>
                            <div class="col-sm-6 col-xl-3">
                                <div class="text-muted">Format</div>
                                <div class="fw-semibold">
                                    <t t-if="document.document_format"
                                       t-out="dict(document._fields['document_format'].selection).get(document.document_format)"/>
                                    <t t-else="">—</t>
                                </div>
                            </div>
                            <div class="col-sm-6 col-xl-3">
                                <div class="text-muted">Version</div>
                                <div class="fw-semibold"><t t-out="document.version or '—'"/></div>
                            </div>
                            <div class="col-sm-6 col-xl-3">
                                <div class="text-muted">Last modified</div>
                                <div class="fw-semibold">
                                    <t t-call="itlingo_website_portal.portal_date">
                                        <t t-set="date_value" t-value="document.write_date"/>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <a t-if="document.document_file"
                               t-attf-href="#{doc_base_url}/#{document.id}/download"
                               class="btn btn-outline-primary">
                                <i class="fa fa-download me-1" aria-hidden="true"/> Download template
                            </a>
                            <a t-if="can_edit_document"
                               t-attf-href="#{doc_base_url}/#{document.id}/edit"
                               class="btn btn-outline-primary">
                                <i class="fa fa-pencil me-1" aria-hidden="true"/> Edit
                            </a>
                            <form t-if="can_edit_document"
                                  t-attf-action="#{doc_base_url}/#{document.id}/delete"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this template? This cannot be undone.');">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-outline-danger">
                                    <i class="fa fa-trash me-1" aria-hidden="true"/> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
