<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_itlingo" model="ir.module.category">
        <field name="name">ITLingo</field>
        <field name="sequence">200</field>
    </record>

    <record id="res_groups_privilege_itlingo" model="res.groups.privilege">
        <field name="name">ITLingo</field>
        <field name="category_id" ref="module_category_itlingo"/>
        <field name="sequence">200</field>
    </record>

    <record id="group_itlingo_member" model="res.groups">
        <field name="name">ITLingo Member</field>
        <field name="privilege_id" ref="res_groups_privilege_itlingo"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[]"/>
        <field name="comment">Base access to ITLingo features (includes Project User for workspaces)</field>
    </record>

    <record id="group_itlingo_manager" model="res.groups">
        <field name="name">ITLingo Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_itlingo"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_itlingo_member'))]"/>
        <field name="comment">Can create organizations and manage projects</field>
    </record>

    <record id="group_itlingo_admin" model="res.groups">
        <field name="name">ITLingo Admin</field>
        <field name="privilege_id" ref="res_groups_privilege_itlingo"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('group_itlingo_manager'))]"/>
        <field name="comment">Full platform administration</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
