<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- ITLingo Admin sees all organizations -->
    <record id="itlingo_organization_rule_admin" model="ir.rule">
        <field name="name">ITLingo Organization: admin sees all</field>
        <field name="model_id" ref="model_itlingo_organization"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_itlingo_admin'))]"/>
    </record>

    <!-- Members see organizations where they have an accepted role -->
    <record id="itlingo_organization_rule_member" model="ir.rule">
        <field name="name">ITLingo Organization: member sees own orgs</field>
        <field name="model_id" ref="model_itlingo_organization"/>
        <field name="domain_force">[('role_ids.user_id', '=', user.id), ('role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('group_itlingo_member'))]"/>
    </record>

    <!-- Portal users see organizations where they have an accepted role -->
    <record id="itlingo_organization_rule_portal" model="ir.rule">
        <field name="name">ITLingo Organization: portal sees own orgs</field>
        <field name="model_id" ref="model_itlingo_organization"/>
        <field name="domain_force">[('role_ids.user_id', '=', user.id), ('role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Org role rules: users see their own roles + admins see all -->
    <record id="itlingo_organization_role_rule_admin" model="ir.rule">
        <field name="name">ITLingo Org Role: admin sees all</field>
        <field name="model_id" ref="model_itlingo_organization_role"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_itlingo_admin'))]"/>
    </record>

    <record id="itlingo_organization_role_rule_member" model="ir.rule">
        <field name="name">ITLingo Org Role: member sees roles in own orgs</field>
        <field name="model_id" ref="model_itlingo_organization_role"/>
        <field name="domain_force">[('organization_id.role_ids.user_id', '=', user.id), ('organization_id.role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('group_itlingo_member'))]"/>
    </record>

    <record id="itlingo_organization_role_rule_portal" model="ir.rule">
        <field name="name">ITLingo Org Role: portal sees own roles</field>
        <field name="model_id" ref="model_itlingo_organization_role"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), '&amp;', ('organization_id.role_ids.user_id', '=', user.id), ('organization_id.role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

</data>
</odoo>
