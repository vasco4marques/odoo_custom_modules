<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="itlingo_organization_role_view_tree" model="ir.ui.view">
        <field name="name">itlingo.organization.role.tree</field>
        <field name="model">itlingo.organization.role</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="organization_id"/>
                <field name="role"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'accepted'"
                       decoration-warning="state == 'pending'"
                       decoration-danger="state == 'rejected'"/>
                <field name="invite_date"/>
                <field name="response_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="itlingo_organization_role_view_form" model="ir.ui.view">
        <field name="name">itlingo.organization.role.form</field>
        <field name="model">itlingo.organization.role</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" string="Accept"
                            type="object" class="btn-success"
                            invisible="state != 'pending'"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,accepted"/>
                </header>
                <sheet>
                    <group>
                        <field name="organization_id"/>
                        <field name="user_id"/>
                        <field name="role"/>
                    </group>
                    <group>
                        <field name="invite_date"/>
                        <field name="response_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="itlingo_organization_role_view_search" model="ir.ui.view">
        <field name="name">itlingo.organization.role.search</field>
        <field name="model">itlingo.organization.role</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="organization_id"/>
                <filter name="pending" string="Pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="accepted" string="Accepted"
                        domain="[('state', '=', 'accepted')]"/>
                <filter name="rejected" string="Rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <group name="group_by">
                    <filter name="group_org" string="Organization"
                            context="{'group_by': 'organization_id'}"/>
                    <filter name="group_role" string="Role"
                            context="{'group_by': 'role'}"/>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="itlingo_organization_role_action" model="ir.actions.act_window">
        <field name="name">Organization Roles</field>
        <field name="res_model">itlingo.organization.role</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_organization_role_view_search"/>
    </record>

</odoo>
