<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="itlingo_organization_view_tree" model="ir.ui.view">
        <field name="name">itlingo.organization.tree</field>
        <field name="model">itlingo.organization</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="organization_type"/>
                <field name="activity_type"/>
                <field name="country_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'suspended'"/>
                <field name="member_count" string="Members"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="itlingo_organization_view_form" model="ir.ui.view">
        <field name="name">itlingo.organization.form</field>
        <field name="model">itlingo.organization</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_suspend" string="Suspend"
                            type="object" class="btn-warning"
                            invisible="state != 'active'"
                            confirm="Are you sure you want to suspend this organization?"/>
                    <button name="action_activate" string="Activate"
                            type="object" class="btn-success"
                            invisible="state != 'suspended'"/>
                    <button name="action_invite_member" string="Invite Member"
                            type="object" class="btn-primary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,suspended"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(itlingo_organization_role_action)d"
                                type="action" class="oe_stat_button"
                                icon="fa-users"
                                context="{'default_organization_id': id, 'search_default_organization_id': id}">
                            <field name="member_count" widget="statinfo" string="Members"/>
                        </button>
                    </div>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Organization Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="organization_type"/>
                            <field name="activity_type"/>
                            <field name="country_id"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Members" name="members">
                            <field name="role_ids">
                                <list editable="bottom">
                                    <field name="user_id"/>
                                    <field name="role"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'accepted'"
                                           decoration-warning="state == 'pending'"
                                           decoration-danger="state == 'rejected'"/>
                                    <field name="invite_date"/>
                                    <field name="response_date"/>
                                    <button name="action_accept" string="Accept"
                                            type="object" icon="fa-check"
                                            invisible="state != 'pending'"/>
                                    <button name="action_reject" string="Reject"
                                            type="object" icon="fa-times"
                                            invisible="state != 'pending'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="itlingo_organization_view_kanban" model="ir.ui.view">
        <field name="name">itlingo.organization.kanban</field>
        <field name="model">itlingo.organization</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <div class="d-flex">
                            <field name="logo" widget="image" class="me-3"
                                   options="{'preview_image': 'logo', 'size': [48, 48]}"/>
                            <div>
                                <field name="name" class="fw-bold fs-5"/>
                                <div class="text-muted">
                                    <field name="activity_type"/>
                                </div>
                                <field name="state" widget="badge"
                                       decoration-success="state == 'active'"
                                       decoration-danger="state == 'suspended'"/>
                            </div>
                        </div>
                        <div class="mt-2">
                            <field name="member_count"/> members
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="itlingo_organization_view_search" model="ir.ui.view">
        <field name="name">itlingo.organization.search</field>
        <field name="model">itlingo.organization</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="country_id"/>
                <filter name="active_orgs" string="Active"
                        domain="[('state', '=', 'active')]"/>
                <filter name="suspended_orgs" string="Suspended"
                        domain="[('state', '=', 'suspended')]"/>
                <separator/>
                <filter name="private" string="Private"
                        domain="[('organization_type', '=', 'private')]"/>
                <filter name="public" string="Public"
                        domain="[('organization_type', '=', 'public')]"/>
                <group name="group_by">
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'organization_type'}"/>
                    <filter name="group_activity" string="Activity Type"
                            context="{'group_by': 'activity_type'}"/>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_country" string="Country"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="itlingo_organization_action" model="ir.actions.act_window">
        <field name="name">Organizations</field>
        <field name="res_model">itlingo.organization</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itlingo_organization_view_search"/>
        <field name="context">{'search_default_active_orgs': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first organization
            </p>
            <p>
                Organizations are the top-level grouping for workspaces and projects.
            </p>
        </field>
    </record>

</odoo>
