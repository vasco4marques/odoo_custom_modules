<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- Demo Organizations -->
    <record id="org_techcorp" model="itlingo.organization">
        <field name="name">TechCorp Solutions</field>
        <field name="organization_type">private</field>
        <field name="activity_type">it</field>
        <field name="state">active</field>
        <field name="description">&lt;p&gt;A leading IT solutions company specializing in software development.&lt;/p&gt;</field>
    </record>

    <record id="org_university" model="itlingo.organization">
        <field name="name">University Research Lab</field>
        <field name="organization_type">public</field>
        <field name="activity_type">education</field>
        <field name="state">active</field>
        <field name="description">&lt;p&gt;Academic research laboratory focused on software engineering.&lt;/p&gt;</field>
    </record>

    <record id="org_consulting" model="itlingo.organization">
        <field name="name">Global Consulting Group</field>
        <field name="organization_type">private</field>
        <field name="activity_type">consulting</field>
        <field name="state">active</field>
        <field name="description">&lt;p&gt;International consulting firm.&lt;/p&gt;</field>
    </record>

    <!-- Demo Organization Roles -->
    <record id="role_admin_techcorp" model="itlingo.organization.role">
        <field name="user_id" ref="base.user_admin"/>
        <field name="organization_id" ref="org_techcorp"/>
        <field name="role">org_manager</field>
        <field name="state">accepted</field>
    </record>

    <record id="role_admin_university" model="itlingo.organization.role">
        <field name="user_id" ref="base.user_admin"/>
        <field name="organization_id" ref="org_university"/>
        <field name="role">org_manager</field>
        <field name="state">accepted</field>
    </record>

    <record id="role_admin_consulting" model="itlingo.organization.role">
        <field name="user_id" ref="base.user_admin"/>
        <field name="organization_id" ref="org_consulting"/>
        <field name="role">org_member</field>
        <field name="state">accepted</field>
    </record>

</data>
</odoo>
