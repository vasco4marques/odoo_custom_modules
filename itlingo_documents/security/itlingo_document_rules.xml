<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <record id="itlingo_document_rule_admin" model="ir.rule">
        <field name="name">ITLingo Document: admin sees all</field>
        <field name="model_id" ref="model_itlingo_document"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <record id="itlingo_document_rule_member" model="ir.rule">
        <field name="name">ITLingo Document: member sees docs in own projects/orgs</field>
        <field name="model_id" ref="model_itlingo_document"/>
        <field name="domain_force">['|',
            '&amp;', ('project_id.workspace_role_ids.user_id', '=', user.id),
                     ('project_id.workspace_role_ids.state', '=', 'accepted'),
            '&amp;', ('organization_id.role_ids.user_id', '=', user.id),
                     ('organization_id.role_ids.state', '=', 'accepted')
        ]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <record id="itlingo_document_rule_portal" model="ir.rule">
        <field name="name">ITLingo Document: portal sees docs in own projects/orgs</field>
        <field name="model_id" ref="model_itlingo_document"/>
        <field name="domain_force">['|',
            '&amp;', ('project_id.workspace_role_ids.user_id', '=', user.id),
                     ('project_id.workspace_role_ids.state', '=', 'accepted'),
            '&amp;', ('organization_id.role_ids.user_id', '=', user.id),
                     ('organization_id.role_ids.state', '=', 'accepted')
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

</data>
</odoo>
