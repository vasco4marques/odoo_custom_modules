<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal home card -->
    <template id="portal_my_home_documents"
              name="Portal Documents"
              inherit_id="portal.portal_my_home"
              priority="60">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/itlingo_documents/static/description/icon.png'"/>
                <t t-set="title">Documents</t>
                <t t-set="url" t-value="'/my/documents'"/>
                <t t-set="text">Browse workspace documents</t>
                <t t-set="count" t-value="document_count"/>
                <t t-set="placeholder_count" t-value="'document_count'"/>
            </t>
        </xpath>
    </template>

    <!-- Document list -->
    <template id="portal_my_documents" name="My Documents">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Documents</t>
            </t>
            <div class="mb-3 d-flex gap-2">
                <a href="/my/workspaces" class="btn btn-outline-primary">My workspaces</a>
                <a t-if="is_admin" href="/my/documents/new" class="btn btn-primary ms-auto">
                    <i class="fa fa-plus"/> New DSL
                </a>
            </div>
            <t t-if="not documents">
                <div class="alert alert-info" role="alert">
                    No documents found.
                </div>
            </t>
            <div class="table-responsive">
                <table class="table table-hover" t-if="documents">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Version</th>
                                <th>Workspace</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="documents" t-as="doc">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/documents/#{doc.id}">
                                            <t t-out="doc.name"/>
                                        </a>
                                    </td>
                                    <td><t t-out="doc.document_type_id.name or '-'"/></td>
                                    <td><t t-out="doc.version"/></td>
                                    <td><t t-out="doc.project_id.name or '-'"/></td>
                                    <td>
                                        <span t-attf-class="badge rounded-pill
                                            #{'text-bg-secondary' if doc.status == 'draft'
                                              else 'text-bg-warning' if doc.status == 'in_review'
                                              else 'text-bg-success' if doc.status == 'approved'
                                              else 'text-bg-primary' if doc.status == 'published'
                                              else 'text-bg-dark'}">
                                            <t t-out="doc.status"/>
                                        </span>
                                    </td>
                                    <td><t t-out="doc.creation_date" t-options='{"widget": "date"}'/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            <div t-if="documents and pager" class="o_portal_pager text-center">
                    <t t-call="portal.pager"/>
                </div>
        </t>
    </template>

    <!-- Document detail -->
    <template id="portal_document_detail" name="Document Detail">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="mb-0"><t t-out="document.name"/></h3>
                    <span t-attf-class="badge rounded-pill
                        #{'text-bg-secondary' if document.status == 'draft'
                          else 'text-bg-warning' if document.status == 'in_review'
                          else 'text-bg-success' if document.status == 'approved'
                          else 'text-bg-primary' if document.status == 'published'
                          else 'text-bg-dark'}">
                        <t t-out="document.status"/>
                    </span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl>
                                <dt>Type</dt>
                                <dd><t t-out="document.document_type_id.name or 'N/A'"/></dd>
                                <dt>Version</dt>
                                <dd><t t-out="document.version"/></dd>
                                <dt>Creator</dt>
                                <dd><t t-out="document.creator_id.name"/></dd>
                                <dt>Created</dt>
                                <dd><t t-out="document.creation_date" t-options='{"widget": "datetime"}'/></dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl>
                                <dt>Workspace</dt>
                                <dd><t t-out="document.project_id.name or 'N/A'"/></dd>
                                <dt>Organization</dt>
                                <dd><t t-out="document.organization_id.name or 'N/A'"/></dd>
                            </dl>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a t-if="document.document_file"
                           t-attf-href="/web/content/#{document.id}?model=itlingo.document&amp;field=document_file&amp;filename_field=file_name&amp;download=true"
                           class="btn btn-primary">
                            <i class="fa fa-download"/> Download File
                        </a>
                        <a t-if="can_edit_document"
                           t-attf-href="/my/documents/#{document.id}/edit"
                           class="btn btn-outline-primary">
                            <i class="fa fa-pencil"/> Edit
                        </a>
                        <form t-if="can_edit_document"
                              t-attf-action="/my/documents/#{document.id}/delete"
                              method="post" class="d-inline"
                              onsubmit="return confirm('Delete this document? This cannot be undone.');">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fa fa-trash"/> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- DSL Files section -->
            <div t-if="document.grammar_file" class="card mt-3">
                <div class="card-header">
                    <h4 class="mb-0">DSL Files</h4>
                </div>
                <div class="card-body">
                    <!-- Grammar -->
                    <div class="mb-4">
                        <h5>Grammar</h5>
                        <div class="d-flex align-items-center gap-2">
                            <span t-if="document.grammar_file_name" class="badge bg-info">
                                <t t-out="document.grammar_file_name"/>
                            </span>
                            <a t-attf-href="/web/content/#{document.id}?model=itlingo.document&amp;field=grammar_file&amp;filename_field=grammar_file_name&amp;download=true"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fa fa-download"/> Download
                            </a>
                            <t t-if="can_edit_document">
                                <form t-attf-action="/my/documents/#{document.id}/upload-file"
                                      method="post" enctype="multipart/form-data" class="d-inline-flex align-items-center gap-1">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="field" value="grammar_file"/>
                                    <input type="file" name="file" accept=".langium" class="form-control form-control-sm" style="width:auto"/>
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fa fa-upload"/> Replace
                                    </button>
                                </form>
                            </t>
                        </div>
                    </div>

                    <!-- Validation Rules -->
                    <div class="mb-4">
                        <h5>Validation Rules</h5>
                        <div class="d-flex align-items-center gap-2">
                            <t t-if="document.validation_rules_file_name">
                                <span class="badge bg-info">
                                    <t t-out="document.validation_rules_file_name"/>
                                </span>
                                <a t-attf-href="/web/content/#{document.id}?model=itlingo.document&amp;field=validation_rules_file&amp;filename_field=validation_rules_file_name&amp;download=true"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-download"/> Download
                                </a>
                            </t>
                            <t t-else="">
                                <span class="text-muted small">No validation rules file</span>
                            </t>
                            <t t-if="can_edit_document">
                                <form t-attf-action="/my/documents/#{document.id}/upload-file"
                                      method="post" enctype="multipart/form-data" class="d-inline-flex align-items-center gap-1">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="field" value="validation_rules_file"/>
                                    <input type="file" name="file" class="form-control form-control-sm" style="width:auto"/>
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fa fa-upload"/> Upload
                                    </button>
                                </form>
                                <form t-if="document.validation_rules_file_name"
                                      t-attf-action="/my/documents/#{document.id}/delete-file"
                                      method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="field" value="validation_rules_file"/>
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this file?');">
                                        <i class="fa fa-trash-o"/> Remove
                                    </button>
                                </form>
                            </t>
                        </div>
                    </div>

                    <!-- Examples -->
                    <div class="mb-4">
                        <h5>Examples</h5>
                        <div class="d-flex align-items-center gap-2">
                            <t t-if="document.examples_file_name">
                                <span class="badge bg-info">
                                    <t t-out="document.examples_file_name"/>
                                </span>
                                <a t-attf-href="/web/content/#{document.id}?model=itlingo.document&amp;field=examples_file&amp;filename_field=examples_file_name&amp;download=true"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fa fa-download"/> Download
                                </a>
                            </t>
                            <t t-else="">
                                <span class="text-muted small">No examples file</span>
                            </t>
                            <t t-if="can_edit_document">
                                <form t-attf-action="/my/documents/#{document.id}/upload-file"
                                      method="post" enctype="multipart/form-data" class="d-inline-flex align-items-center gap-1">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="field" value="examples_file"/>
                                    <input type="file" name="file" class="form-control form-control-sm" style="width:auto"/>
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fa fa-upload"/> Upload
                                    </button>
                                </form>
                                <form t-if="document.examples_file_name"
                                      t-attf-action="/my/documents/#{document.id}/delete-file"
                                      method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="field" value="examples_file"/>
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this file?');">
                                        <i class="fa fa-trash-o"/> Remove
                                    </button>
                                </form>
                            </t>
                        </div>
                    </div>

                    <!-- Specification Examples -->
                    <div class="mb-4">
                        <h5>Specification Examples</h5>
                        <t t-if="document.spec_example_file_ids">
                            <div class="d-flex flex-column gap-1 mb-2">
                                <t t-foreach="document.spec_example_file_ids" t-as="spec">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-info">
                                            <t t-out="spec.name"/>
                                        </span>
                                        <a t-attf-href="/web/content/#{spec.id}?model=itlingo.document.spec.file&amp;field=file_data&amp;filename_field=name&amp;download=true"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fa fa-download"/> Download
                                        </a>
                                        <form t-if="can_edit_document"
                                              t-attf-action="/my/documents/#{document.id}/delete-spec-file/#{spec.id}"
                                              method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete this file?');">
                                                <i class="fa fa-trash-o"/> Remove
                                            </button>
                                        </form>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <p class="text-muted small">No specification examples</p>
                        </t>
                        <form t-if="can_edit_document"
                              t-attf-action="/my/documents/#{document.id}/add-spec-file"
                              method="post" enctype="multipart/form-data" class="d-flex align-items-center gap-1">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="file" name="spec_example_files" multiple="" class="form-control form-control-sm" style="width:auto"/>
                            <button type="submit" class="btn btn-sm btn-success">
                                <i class="fa fa-plus"/> Add
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="document"/>
                </t>
            </div>
        </t>
    </template>

    <template id="portal_document_edit" name="Document Edit">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header">
                    <h3 class="mb-0">Edit document: <t t-out="document.name"/></h3>
                </div>
                <div class="card-body">
                    <div t-if="error.get('_form')" class="alert alert-danger" role="alert">
                        <t t-out="error['_form']"/>
                    </div>
                    <form t-attf-action="/my/documents/#{document.id}/edit"
                          method="post" enctype="multipart/form-data">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="form-label" for="doc_edit_name">Name</label>
                            <input type="text" class="form-control" id="doc_edit_name" name="name" required=""
                                   t-att-value="form.get('name') or ''"/>
                            <div t-if="error.get('name')" class="text-danger small mt-1"><t t-out="error['name']"/></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="doc_edit_type">Document type</label>
                            <select class="form-select" id="doc_edit_type" name="document_type_id">
                                <option value="">—</option>
                                <t t-foreach="doc_types" t-as="dt">
                                    <option t-att-value="dt.id"
                                            t-att-selected="str(form.get('document_type_id') or '') == str(dt.id)">
                                        <t t-out="dt.name"/>
                                    </option>
                                </t>
                            </select>
                            <div t-if="error.get('document_type_id')" class="text-danger small mt-1"><t t-out="error['document_type_id']"/></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="doc_edit_status">Status</label>
                            <select class="form-select" id="doc_edit_status" name="status">
                                <t t-foreach="status_selection" t-as="opt">
                                    <option t-att-value="opt[0]"
                                            t-att-selected="(form.get('status') or document.status) == opt[0]">
                                        <t t-out="opt[1]"/>
                                    </option>
                                </t>
                            </select>
                            <div t-if="error.get('status')" class="text-danger small mt-1"><t t-out="error['status']"/></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="doc_edit_version">Version</label>
                            <input type="text" class="form-control" id="doc_edit_version" name="version"
                                   t-att-value="form.get('version') or ''"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="doc_edit_file">Replace file (optional)</label>
                            <input type="file" class="form-control" id="doc_edit_file" name="document_file"/>
                            <div t-if="document.file_name" class="form-text">
                                Current file: <t t-out="document.file_name"/>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save</button>
                            <a t-attf-href="/my/documents/#{document.id}" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_document_create" name="New DSL">
        <t t-call="portal.portal_layout">
            <div class="card mt-3">
                <div class="card-header">
                    <h3 class="mb-0">New DSL</h3>
                </div>
                <div class="card-body">
                    <div t-if="error.get('_form')" class="alert alert-danger" role="alert">
                        <t t-out="error['_form']"/>
                    </div>
                    <form action="/my/documents/new"
                          method="post" enctype="multipart/form-data">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <!-- DSL Name -->
                        <div class="mb-3">
                            <label class="form-label" for="doc_create_name">Name (DSL name)</label>
                            <input type="text" class="form-control" id="doc_create_name" name="name" required=""
                                   t-att-value="form.get('name') or ''"/>
                            <div t-if="error.get('name')" class="text-danger small mt-1"><t t-out="error['name']"/></div>
                        </div>
                        <!-- Grammar -->
                        <div class="mb-3">
                            <label class="form-label" for="doc_create_grammar">Grammar</label>
                            <input type="file" class="form-control" id="doc_create_grammar" name="grammar_file"
                                   accept=".langium" required=""/>
                            <div t-if="error.get('grammar_file')" class="text-danger small mt-1"><t t-out="error['grammar_file']"/></div>
                            <div class="form-text">File extension must be .langium</div>
                        </div>
                        <!-- Validation Rules (Optional) -->
                        <div class="mb-3">
                            <label class="form-label" for="doc_create_valrules">(Optional) Validation Rules</label>
                            <input type="file" class="form-control" id="doc_create_valrules" name="validation_rules_file"/>
                            <div class="form-text">Max 1 file</div>
                        </div>
                        <!-- Examples (Optional) -->
                        <div class="mb-3">
                            <label class="form-label" for="doc_create_examples">(Optional) Examples</label>
                            <input type="file" class="form-control" id="doc_create_examples" name="examples_file"/>
                            <div class="form-text">Max 1 file</div>
                        </div>
                        <!-- Specification Example (Optional, multiple) -->
                        <div class="mb-3">
                            <label class="form-label" for="doc_create_spec_examples">(Optional) Specification Example</label>
                            <input type="file" class="form-control" id="doc_create_spec_examples" name="spec_example_files" multiple=""/>
                            <div class="form-text">0 or more files</div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Create</button>
                            <a href="/my/documents" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

</odoo>
