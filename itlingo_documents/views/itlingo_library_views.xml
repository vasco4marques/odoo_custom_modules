<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_library_view_tree" model="ir.ui.view">
        <field name="name">itlingo.library.tree</field>
        <field name="model">itlingo.library</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="document_count" string="Documents"/>
            </list>
        </field>
    </record>

    <record id="itlingo_library_view_form" model="ir.ui.view">
        <field name="name">itlingo.library.form</field>
        <field name="model">itlingo.library</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <field name="document_library_ids">
                        <list>
                            <field name="document_id"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_library_action" model="ir.actions.act_window">
        <field name="name">Libraries</field>
        <field name="res_model">itlingo.library</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
