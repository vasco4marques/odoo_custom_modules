<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_document_template_view_tree" model="ir.ui.view">
        <field name="name">itlingo.document.template.tree</field>
        <field name="model">itlingo.document.template</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="itlingo_document_template_view_form" model="ir.ui.view">
        <field name="name">itlingo.document.template.form</field>
        <field name="model">itlingo.document.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_document_template_action" model="ir.actions.act_window">
        <field name="name">Document Templates</field>
        <field name="res_model">itlingo.document.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
