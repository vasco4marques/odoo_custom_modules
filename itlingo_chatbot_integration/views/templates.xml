<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="chat_page" name="Workspace Chat Page">
        <t t-call="portal.portal_layout">
            <t t-set="hide_project_breadcrumbs" t-value="True"/>
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title" t-value="project.name"/>
            </t>

            <style>
                .itlingo-chat-page {
                    display: flex;
                    flex-direction: column;
                    min-height: calc(100vh - 280px);
                }

                .itlingo-chat-frame-card {
                    flex: 1 1 auto;
                    min-height: 0;
                    overflow: hidden;
                }

                .itlingo-chat-frame {
                    width: 100%;
                    height: 100%;
                    min-height: 78vh;
                    border: 0;
                }

                @media (max-width: 991.98px) {
                    .itlingo-chat-page {
                        min-height: calc(100vh - 260px);
                    }

                    .itlingo-chat-frame {
                        min-height: 80vh;
                    }
                }
            </style>

            <div class="itlingo-chat-page">
                <div class="card border-0 shadow-sm rounded-3 itlingo-chat-frame-card">
                    <iframe class="itlingo-chat-frame"
                            t-att-src="chat_url + ('?workspace_key=' + (project.workspace_key or '') + '&amp;workspace_id=' + str(project_id) + ('&amp;token=' + token if token else ''))"
                            title="Workspace Chat"
                            allow="microphone; camera; clipboard-write; fullscreen"/>
                </div>
            </div>
        </t>
    </template>

    <!-- Breadcrumbs for the chat page, matching the other workspace pages:
         Home / Public workspaces / <workspace> / Chatbot   (anonymous hub)
         Home / Workspaces / <workspace> / Chatbot          (member hub)   -->
    <template id="portal_chat_breadcrumbs" name="Chat page breadcrumbs"
              inherit_id="portal.portal_breadcrumbs" priority="55">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'workspace_chat' and workspace_hub_public" class="breadcrumb-item">
                <a href="/public-workspaces">Public workspaces</a>
            </li>
            <li t-if="page_name == 'workspace_chat' and not workspace_hub_public" class="breadcrumb-item">
                <a href="/my/workspaces">Workspaces</a>
            </li>
            <li t-if="page_name == 'workspace_chat'" class="breadcrumb-item text-truncate">
                <a t-att-href="ws_hub_prefix"><t t-out="project.name"/></a>
            </li>
            <li t-if="page_name == 'workspace_chat'" class="breadcrumb-item active">Chatbot</li>
        </xpath>
    </template>

    <!-- add a Chat link to workspace hub nav, after Specifications.
         Uses ws_hub_prefix so it also works on the public (anonymous,
         read-only) workspace hub. -->
    <template id="portal_add_chat_link" inherit_id="itlingo_website_portal.portal_workspace_hub_shell">
        <xpath expr="//a[contains(@t-attf-href, '/specifications')]" position="after">
            <a t-attf-href="#{ws_hub_prefix}/chat" t-attf-class="nav-link itlingo-org-hub__nav-link rounded-2 #{workspace_hub_page == 'chat' and 'active' or ''}">
                <i class="fa fa-comments fa-fw me-2" aria-hidden="true"/>Chatbot
            </a>
        </xpath>
    </template>
</odoo>
