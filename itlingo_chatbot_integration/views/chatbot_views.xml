<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_chat_workspace_view_tree" model="ir.ui.view">
        <field name="name">itlingo.chat.workspace.tree</field>
        <field name="model">itlingo.chat.workspace</field>
        <field name="arch" type="xml">
            <list>
                <field name="odoo_project_id"/>
                <field name="workspace_key"/>
                <field name="workspace_name"/>
                <field name="current_thread_id"/>
            </list>
        </field>
    </record>

    <record id="itlingo_chat_workspace_view_form" model="ir.ui.view">
        <field name="name">itlingo.chat.workspace.form</field>
        <field name="model">itlingo.chat.workspace</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="odoo_project_id"/>
                        <field name="workspace_key"/>
                        <field name="workspace_name"/>
                        <field name="current_thread_id"/>
                    </group>
                    <group>
                        <field name="created_at" readonly="1"/>
                        <field name="updated_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_chat_workspace_view_search" model="ir.ui.view">
        <field name="name">itlingo.chat.workspace.search</field>
        <field name="model">itlingo.chat.workspace</field>
        <field name="arch" type="xml">
            <search>
                <field name="odoo_project_id"/>
                <field name="workspace_key"/>
                <field name="workspace_name"/>
            </search>
        </field>
    </record>

    <record id="itlingo_chat_workspace_action" model="ir.actions.act_window">
        <field name="name">Chat Workspaces</field>
        <field name="res_model">itlingo.chat.workspace</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_chat_workspace_view_search"/>
    </record>

    <record id="itlingo_chat_folder_view_tree" model="ir.ui.view">
        <field name="name">itlingo.chat.folder.tree</field>
        <field name="model">itlingo.chat.folder</field>
        <field name="arch" type="xml">
            <list>
                <field name="workspace_key"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="itlingo_chat_folder_view_form" model="ir.ui.view">
        <field name="name">itlingo.chat.folder.form</field>
        <field name="model">itlingo.chat.folder</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="workspace_key"/>
                        <field name="name"/>
                    </group>
                    <group>
                        <field name="created_at" readonly="1"/>
                        <field name="updated_at" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Threads">
                            <field name="thread_ids">
                                <list>
                                    <field name="workspace_key"/>
                                    <field name="title"/>
                                </list>
                            </field>
                        </page>
                        <page string="Files">
                            <field name="file_ids">
                                <list>
                                    <field name="workspace_key"/>
                                    <field name="file_name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_chat_folder_view_search" model="ir.ui.view">
        <field name="name">itlingo.chat.folder.search</field>
        <field name="model">itlingo.chat.folder</field>
        <field name="arch" type="xml">
            <search>
                <field name="workspace_key"/>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="itlingo_chat_folder_action" model="ir.actions.act_window">
        <field name="name">Chat Folders</field>
        <field name="res_model">itlingo.chat.folder</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_chat_folder_view_search"/>
    </record>

    <record id="itlingo_chat_thread_view_tree" model="ir.ui.view">
        <field name="name">itlingo.chat.thread.tree</field>
        <field name="model">itlingo.chat.thread</field>
        <field name="arch" type="xml">
            <list>
                <field name="workspace_key"/>
                <field name="title"/>
                <field name="folder_id"/>
            </list>
        </field>
    </record>

    <record id="itlingo_chat_thread_view_form" model="ir.ui.view">
        <field name="name">itlingo.chat.thread.form</field>
        <field name="model">itlingo.chat.thread</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="workspace_key"/>
                        <field name="title"/>
                        <field name="folder_id"/>
                    </group>
                    <group>
                        <field name="created_at" readonly="1"/>
                        <field name="updated_at" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Messages">
                            <field name="message_ids">
                                <list>
                                    <field name="workspace_key"/>
                                    <field name="role"/>
                                    <field name="content_preview" string="Content"/>
                                    <field name="model"/>
                                </list>
                            </field>
                        </page>
                        <page string="Files">
                            <field name="file_ids">
                                <list>
                                    <field name="workspace_key"/>
                                    <field name="file_name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_chat_thread_view_search" model="ir.ui.view">
        <field name="name">itlingo.chat.thread.search</field>
        <field name="model">itlingo.chat.thread</field>
        <field name="arch" type="xml">
            <search>
                <field name="workspace_key"/>
                <field name="title"/>
                <field name="folder_id"/>
            </search>
        </field>
    </record>

    <record id="itlingo_chat_thread_action" model="ir.actions.act_window">
        <field name="name">Chat Threads</field>
        <field name="res_model">itlingo.chat.thread</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_chat_thread_view_search"/>
    </record>

    <record id="itlingo_chat_message_view_tree" model="ir.ui.view">
        <field name="name">itlingo.chat.message.tree</field>
        <field name="model">itlingo.chat.message</field>
        <field name="arch" type="xml">
            <list>
                <field name="workspace_key"/>
                <field name="thread_id"/>
                <field name="role"/>
                <field name="content_preview" string="Content"/>
                <field name="model"/>
                <field name="agentic_generation"/>
                <field name="rag_sources"/>
                <field name="timestamp"/>
            </list>
        </field>
    </record>

    <record id="itlingo_chat_message_view_form" model="ir.ui.view">
        <field name="name">itlingo.chat.message.form</field>
        <field name="model">itlingo.chat.message</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="workspace_key"/>
                        <field name="thread_id"/>
                        <field name="role"/>
                        <field name="model"/>
                        <field name="model_auto_switched"/>
                    </group>
                    <group>
                        <field name="content" nolabel="1"/>
                    </group>
                    <group>
                        <field name="models_used"/>
                        <field name="tokens"/>
                        <field name="rag_sources"/>
                        <field name="agentic_generation"/>
                    </group>
                    <group>
                        <field name="timestamp" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="File Links">
                            <field name="file_link_ids">
                                <list>
                                    <field name="thread_file_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_chat_message_view_search" model="ir.ui.view">
        <field name="name">itlingo.chat.message.search</field>
        <field name="model">itlingo.chat.message</field>
        <field name="arch" type="xml">
            <search>
                <field name="workspace_key"/>
                <field name="thread_id"/>
                <field name="role"/>
                <field name="content_preview" string="Content"/>
            </search>
        </field>
    </record>

    <record id="itlingo_chat_message_action" model="ir.actions.act_window">
        <field name="name">Chat Messages</field>
        <field name="res_model">itlingo.chat.message</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_chat_message_view_search"/>
    </record>

    <record id="itlingo_thread_file_view_tree" model="ir.ui.view">
        <field name="name">itlingo.thread.file.tree</field>
        <field name="model">itlingo.thread.file</field>
        <field name="arch" type="xml">
            <list>
                <field name="workspace_key"/>
                <field name="thread_id"/>
                <field name="folder_id"/>
                <field name="file_size_bytes"/>
                <field name="extension"/>
                <field name="mime_type"/>
            </list>
        </field>
    </record>

    <record id="itlingo_thread_file_view_form" model="ir.ui.view">
        <field name="name">itlingo.thread.file.form</field>
        <field name="model">itlingo.thread.file</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="workspace_key"/>
                        <field name="thread_id"/>
                        <field name="folder_id"/>
                        <field name="file_name"/>
                    </group>
                    <group>
                        <field name="file_size_bytes"/>
                        <field name="extension"/>
                        <field name="mime_type"/>
                        <field name="extraction_method"/>
                        <field name="preserve_full_context"/>
                    </group>
                    <group>
                        <field name="extracted_content" nolabel="1"/>
                    </group>
                    <group>
                        <field name="created_at" readonly="1"/>
                        <field name="updated_at" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Chunks">
                            <field name="chunk_ids">
                                <list>
                                    <field name="chunk_index"/>
                                    <field name="content"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_thread_file_view_search" model="ir.ui.view">
        <field name="name">itlingo.thread.file.search</field>
        <field name="model">itlingo.thread.file</field>
        <field name="arch" type="xml">
            <search>
                <field name="workspace_key"/>
                <field name="thread_id"/>
                <field name="folder_id"/>
                <field name="file_name"/>
            </search>
        </field>
    </record>

    <record id="itlingo_thread_file_action" model="ir.actions.act_window">
        <field name="name">Thread Files</field>
        <field name="res_model">itlingo.thread.file</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_thread_file_view_search"/>
    </record>

    <record id="itlingo_thread_file_chunk_view_tree" model="ir.ui.view">
        <field name="name">itlingo.thread.file.chunk.tree</field>
