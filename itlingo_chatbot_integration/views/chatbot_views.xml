    <record id="itlingo_model_usage_view_tree" model="ir.ui.view">
        <field name="name">itlingo.model.usage.tree</field>
        <field name="model">itlingo.model.usage</field>
        <field name="arch" type="xml">
            <list>
                <field name="timestamp"/>
                <field name="provider"/>
                <field name="model"/>
                <field name="input_tokens"/>
                <field name="output_tokens"/>
                <field name="total_tokens"/>
            </list>
        </field>
    </record>

    <record id="itlingo_model_usage_view_form" model="ir.ui.view">
        <field name="name">itlingo.model.usage.form</field>
        <field name="model">itlingo.model.usage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="timestamp" readonly="1"/>
                        <field name="provider"/>
                        <field name="model"/>
                    </group>
                    <group>
                        <field name="input_tokens"/>
                        <field name="output_tokens"/>
                        <field name="total_tokens"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_model_usage_view_search" model="ir.ui.view">
        <field name="name">itlingo.model.usage.search</field>
        <field name="model">itlingo.model.usage</field>
        <field name="arch" type="xml">
            <search>
                <field name="provider"/>
                <field name="model"/>
                <filter name="group_provider" string="Provider" context="{'group_by': 'provider'}"/>
                <filter name="group_model" string="Model" context="{'group_by': 'model'}"/>
            </search>
        </field>
    </record>

    <record id="itlingo_model_usage_action" model="ir.actions.act_window">
        <field name="name">Model Usage</field>
        <field name="res_model">itlingo.model.usage</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_model_usage_view_search"/>
    </record>

