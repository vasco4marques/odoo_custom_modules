            </search>
        </field>
    </record>

    <record id="itlingo_thread_file_chunk_action" model="ir.actions.act_window">
        <field name="name">Thread File Chunks</field>
        <field name="res_model">itlingo.thread.file.chunk</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_thread_file_chunk_view_search"/>
    </record>

    <record id="itlingo_message_file_link_view_tree" model="ir.ui.view">
        <field name="name">itlingo.message.file.link.tree</field>
        <field name="model">itlingo.message.file.link</field>
        <field name="arch" type="xml">
            <list>
                <field name="message_id"/>
                <field name="thread_file_id"/>
            </list>
        </field>
    </record>

    <record id="itlingo_message_file_link_view_form" model="ir.ui.view">
        <field name="name">itlingo.message.file.link.form</field>
        <field name="model">itlingo.message.file.link</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="message_id"/>
                        <field name="thread_file_id"/>
                    </group>
                    <group>
                        <field name="created_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_message_file_link_view_search" model="ir.ui.view">
        <field name="name">itlingo.message.file.link.search</field>
        <field name="model">itlingo.message.file.link</field>
        <field name="arch" type="xml">
            <search>
                <field name="message_id"/>
