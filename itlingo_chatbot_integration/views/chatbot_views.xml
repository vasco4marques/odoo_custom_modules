    </record>

    <record id="itlingo_thread_file_chunk_view_form" model="ir.ui.view">
        <field name="name">itlingo.thread.file.chunk.form</field>
        <field name="model">itlingo.thread.file.chunk</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="thread_file_id"/>
                        <field name="chunk_index"/>
                    </group>
