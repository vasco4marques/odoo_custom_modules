<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- Demo Sprints -->
    <record id="sprint_1" model="itlingo.sprint">
        <field name="name">Sprint 1 - Foundation</field>
        <field name="project_id" ref="itlingo_workspace_access.project_itlingo_platform"/>
        <field name="start_date" eval="(DateTime.today() - relativedelta(days=14)).strftime('%Y-%m-%d')"/>
        <field name="end_date" eval="DateTime.today().strftime('%Y-%m-%d')"/>
        <field name="state">executing</field>
        <field name="goal">Set up project infrastructure and core models.</field>
        <field name="sequence">1</field>
    </record>

    <record id="sprint_2" model="itlingo.sprint">
        <field name="name">Sprint 2 - Features</field>
        <field name="project_id" ref="itlingo_workspace_access.project_itlingo_platform"/>
        <field name="start_date" eval="(DateTime.today() + relativedelta(days=1)).strftime('%Y-%m-%d')"/>
        <field name="end_date" eval="(DateTime.today() + relativedelta(days=14)).strftime('%Y-%m-%d')"/>
        <field name="state">not_started</field>
        <field name="goal">Implement core features and views.</field>
        <field name="sequence">2</field>
    </record>

    <!-- Demo Backlog Items -->
    <record id="backlog_item_1" model="itlingo.backlog.item">
        <field name="name">As a user, I can create an organization</field>
        <field name="item_type">user_story</field>
        <field name="story_points">5</field>
        <field name="priority">hi</field>
        <field name="status">done</field>
        <field name="project_id" ref="itlingo_workspace_access.project_itlingo_platform"/>
        <field name="sprint_id" ref="sprint_1"/>
    </record>

    <record id="backlog_item_2" model="itlingo.backlog.item">
        <field name="name">As a user, I can invite members to my organization</field>
        <field name="item_type">user_story</field>
        <field name="story_points">8</field>
        <field name="priority">hi</field>
        <field name="status">in_progress</field>
        <field name="project_id" ref="itlingo_workspace_access.project_itlingo_platform"/>
        <field name="sprint_id" ref="sprint_1"/>
    </record>

    <record id="backlog_item_3" model="itlingo.backlog.item">
        <field name="name">Sprint board view for tasks</field>
        <field name="item_type">feature</field>
        <field name="story_points">13</field>
        <field name="priority">med</field>
        <field name="status">new</field>
        <field name="project_id" ref="itlingo_workspace_access.project_itlingo_platform"/>
        <field name="sprint_id" ref="sprint_2"/>
    </record>

    <record id="backlog_item_4" model="itlingo.backlog.item">
        <field name="name">Fix login redirect after password reset</field>
        <field name="item_type">bug</field>
        <field name="story_points">2</field>
        <field name="priority">vhi</field>
        <field name="status">ready</field>
        <field name="project_id" ref="itlingo_workspace_access.project_itlingo_platform"/>
    </record>

</data>
</odoo>
