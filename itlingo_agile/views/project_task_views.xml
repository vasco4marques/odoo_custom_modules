<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend task form view -->
    <record id="project_task_view_form_inherit_itlingo_agile" model="ir.ui.view">
        <field name="name">project.task.form.inherit.itlingo.agile</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="sprint_id"/>
                <field name="backlog_item_id"/>
                <field name="task_type"/>
                <field name="planned_effort"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Day Efforts" name="day_efforts">
                    <div class="alert alert-info mb-3" role="status">
                        Add rows to log hours per day and person. New tasks receive a starter
                        row for each assignee (today, actual, 0 h); edit or add rows as needed.
                    </div>
                    <field name="day_effort_ids">
                        <list editable="bottom">
                            <field name="day"/>
                            <field name="user_id"/>
                            <field name="hours"/>
                            <field name="allocation_percentage"/>
                            <field name="effort_type"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extend task list view -->
    <record id="project_task_view_tree_inherit_itlingo_agile" model="ir.ui.view">
        <field name="name">project.task.tree.inherit.itlingo.agile</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="sprint_id" optional="show"/>
                <field name="task_type" optional="hide"/>
                <field name="planned_effort" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Extend task search view -->
    <record id="project_task_view_search_inherit_itlingo_agile" model="ir.ui.view">
        <field name="name">project.task.search.inherit.itlingo.agile</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="sprint_id"/>
                <field name="backlog_item_id"/>
                <group name="group_by">
                    <filter name="group_sprint" string="Sprint"
                            context="{'group_by': 'sprint_id'}"/>
                    <filter name="group_task_type" string="Task Type"
                            context="{'group_by': 'task_type'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
