<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="itlingo_backlog_item_view_tree" model="ir.ui.view">
        <field name="name">itlingo.backlog.item.tree</field>
        <field name="model">itlingo.backlog.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="identifier"/>
                <field name="name"/>
                <field name="item_type"/>
                <field name="project_id" string="Workspace"/>
                <field name="sprint_id"/>
                <field name="story_points"/>
                <field name="priority"/>
                <field name="status" widget="badge"
                       decoration-info="status == 'new'"
                       decoration-warning="status == 'ready'"
                       decoration-primary="status == 'in_progress'"
                       decoration-success="status == 'done'"
                       decoration-danger="status == 'canceled'"/>
                <field name="task_count" string="Tasks"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="itlingo_backlog_item_view_form" model="ir.ui.view">
        <field name="name">itlingo.backlog.item.form</field>
        <field name="model">itlingo.backlog.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="new,ready,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-tasks"
                                name="action_view_tasks" type="object">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="identifier" class="me-2" readonly="1"/>
                            <field name="name" placeholder="Backlog Item Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="item_type"/>
                            <field name="priority"/>
                            <field name="story_points"/>
                            <field name="actual_effort"/>
                        </group>
                        <group>
                            <field name="project_id" string="Workspace"/>
                            <field name="sprint_id"/>
                            <field name="initial_sprint_id"/>
                            <field name="final_sprint_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="document_item_id"/>
                            <field name="combined_with_story_points"/>
                        </group>
                    </group>
                    <separator string="Description"/>
                    <field name="description"/>
                    <notebook>
                        <page string="Execution tasks (optional)" name="tasks">
                            <div class="alert alert-secondary mb-2" role="status">
                                Optional Odoo tasks for technical breakdown. Planning and sprints use this backlog item as the main unit of work.
                            </div>
                            <field name="task_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="task_type"/>
                                    <field name="state"/>
                                    <field name="planned_effort"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="itlingo_backlog_item_view_kanban" model="ir.ui.view">
        <field name="name">itlingo.backlog.item.kanban</field>
        <field name="model">itlingo.backlog.item</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <field name="identifier" class="text-muted small"/>
                            <field name="priority" widget="priority"/>
                        </div>
                        <field name="name" class="fw-bold"/>
                        <div class="text-muted small mt-1">
                            <field name="item_type"/> |
                            <field name="story_points"/> SP
                        </div>
                        <div class="mt-1">
                            <span class="badge bg-secondary"><field name="task_count"/> tasks</span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="itlingo_backlog_item_view_search" model="ir.ui.view">
        <field name="name">itlingo.backlog.item.search</field>
        <field name="model">itlingo.backlog.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="identifier"/>
                <field name="project_id"/>
                <field name="sprint_id"/>
                <filter name="user_stories" string="User Stories"
                        domain="[('item_type', '=', 'user_story')]"/>
                <filter name="bugs" string="Bugs"
                        domain="[('item_type', '=', 'bug')]"/>
                <filter name="epics" string="Epics"
                        domain="[('item_type', '=', 'epic')]"/>
                <separator/>
                <filter name="product_backlog" string="Product backlog (no sprint)"
                        domain="[('sprint_id', '=', False)]"/>
                <filter name="new" string="New"
                        domain="[('status', '=', 'new')]"/>
                <filter name="in_progress" string="In Progress"
                        domain="[('status', '=', 'in_progress')]"/>
                <filter name="done" string="Done"
                        domain="[('status', '=', 'done')]"/>
                <group name="group_by">
                    <filter name="group_project" string="Workspace"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_sprint" string="Sprint"
                            context="{'group_by': 'sprint_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'item_type'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_priority" string="Priority"
                            context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="itlingo_backlog_item_action" model="ir.actions.act_window">
        <field name="name">Backlog Items</field>
        <field name="res_model">itlingo.backlog.item</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itlingo_backlog_item_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first backlog item
            </p>
        </field>
    </record>

</odoo>
