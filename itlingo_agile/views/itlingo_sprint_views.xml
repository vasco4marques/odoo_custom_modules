<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="itlingo_sprint_view_tree" model="ir.ui.view">
        <field name="name">itlingo.sprint.tree</field>
        <field name="model">itlingo.sprint</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id" string="Workspace"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'not_started'"
                       decoration-success="state == 'executing'"
                       decoration-muted="state == 'closed'"
                       decoration-danger="state == 'canceled'"/>
                <field name="total_story_points"/>
                <field name="completed_story_points"/>
                <field name="backlog_item_count" string="Items"/>
                <field name="task_count" string="Tasks"/>
            </list>
        </field>
    </record>

    <!-- Declared before sprint form stat buttons (XML id resolution) -->
    <record id="itlingo_sprint_task_action" model="ir.actions.act_window">
        <field name="name">Sprint Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <!-- Form View -->
    <record id="itlingo_sprint_view_form" model="ir.ui.view">
        <field name="name">itlingo.sprint.form</field>
        <field name="model">itlingo.sprint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Start Sprint"
                            type="object" class="btn-success"
                            invisible="state != 'not_started'"/>
                    <button name="action_close" string="Close Sprint"
                            type="object" class="btn-primary"
                            invisible="state != 'executing'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-warning"
                            invisible="state in ('closed', 'canceled')"/>
                    <button name="action_reset" string="Reset"
                            type="object"
                            invisible="state not in ('canceled',)"/>
                    <button name="action_open_plan_backlog_wizard" string="Add from product backlog"
                            type="object" class="btn-secondary"
                            invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="not_started,executing,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list"
                                name="%(itlingo_backlog_item_action)d"
                                type="action"
                                context="{'search_default_sprint_id': id, 'default_sprint_id': id, 'default_project_id': project_id}">
                            <field name="backlog_item_count" widget="statinfo" string="Backlog Items"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-tasks"
                                name="%(itlingo_sprint_task_action)d"
                                type="action"
                                context="{'search_default_sprint_id': id, 'default_sprint_id': id, 'default_project_id': project_id}">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Sprint Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" string="Workspace"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="actual_end"/>
                        </group>
                    </group>
                    <group>
                        <group string="Progress">
                            <field name="total_story_points"/>
                            <field name="completed_story_points"/>
                        </group>
                    </group>
                    <separator string="Goal"/>
                    <field name="goal" placeholder="Sprint goal..."/>
                    <notebook>
                        <page string="Backlog Items" name="backlog_items">
                            <div class="alert alert-info mb-2" role="status">
                                Use <b>Add from product backlog</b> to link existing items.
                                This list is read-only here to avoid accidental deletes.
                            </div>
                            <field name="backlog_item_ids">
                                <list create="false" delete="false" edit="false">
                                    <field name="identifier"/>
                                    <field name="name"/>
                                    <field name="item_type"/>
                                    <field name="story_points"/>
                                    <field name="priority"/>
                                    <field name="status" widget="badge"
                                           decoration-info="status == 'new'"
                                           decoration-warning="status == 'ready'"
                                           decoration-primary="status == 'in_progress'"
                                           decoration-success="status == 'done'"
                                           decoration-danger="status == 'canceled'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Sprint Users" name="sprint_users">
                            <field name="sprint_user_ids">
                                <list editable="bottom">
                                    <field name="user_id"/>
                                    <field name="dev_utilization"/>
                                    <field name="daily_work_hours"/>
                                    <field name="dev_daily_hours"/>
                                    <field name="dev_total_hours"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="itlingo_sprint_view_kanban" model="ir.ui.view">
        <field name="name">itlingo.sprint.kanban</field>
        <field name="model">itlingo.sprint</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold"/>
                        <field name="project_id" class="text-muted"/>
                        <div class="mt-2">
                            <field name="start_date"/> - <field name="end_date"/>
                        </div>
                        <div class="mt-1">
                            <span class="badge bg-info"><field name="backlog_item_count"/> items</span>
                            <span class="badge bg-secondary ms-1"><field name="task_count"/> tasks</span>
                        </div>
                        <div class="mt-1">
                            SP: <field name="completed_story_points"/> / <field name="total_story_points"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="itlingo_sprint_view_search" model="ir.ui.view">
        <field name="name">itlingo.sprint.search</field>
        <field name="model">itlingo.sprint</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <filter name="not_started" string="Not Started"
                        domain="[('state', '=', 'not_started')]"/>
                <filter name="executing" string="Executing"
                        domain="[('state', '=', 'executing')]"/>
                <filter name="closed" string="Closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <group name="group_by">
                    <filter name="group_project" string="Workspace"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="itlingo_sprint_action" model="ir.actions.act_window">
        <field name="name">Sprints</field>
        <field name="res_model">itlingo.sprint</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itlingo_sprint_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sprint
            </p>
        </field>
    </record>

</odoo>
