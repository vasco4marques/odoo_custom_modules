<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="project_project_view_form_itlingo_hub" model="ir.ui.view">
        <field name="name">project.project.form.itlingo.hub</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="itlingo_workspace_access.project_project_view_form_inherit_itlingo"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_itlingo_sprints" type="object"
                        class="oe_stat_button" icon="fa-refresh"
                        title="Open sprints for this workspace">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Sprints</span>
                    </div>
                </button>
                <button name="action_view_product_backlog" type="object"
                        class="oe_stat_button" icon="fa-list-alt"
                        title="Open product backlog for this workspace">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Backlog</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
