<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="itlingo_task_day_effort_view_tree" model="ir.ui.view">
        <field name="name">itlingo.task.day.effort.tree</field>
        <field name="model">itlingo.task.day.effort</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="task_id"/>
                <field name="user_id"/>
                <field name="day"/>
                <field name="hours"/>
                <field name="allocation_percentage"/>
                <field name="effort_type"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="itlingo_task_day_effort_view_search" model="ir.ui.view">
        <field name="name">itlingo.task.day.effort.search</field>
        <field name="model">itlingo.task.day.effort</field>
        <field name="arch" type="xml">
            <search>
                <field name="task_id"/>
                <field name="user_id"/>
                <filter name="actual" string="Actual"
                        domain="[('effort_type', '=', 'actual')]"/>
                <filter name="remaining" string="Remaining"
                        domain="[('effort_type', '=', 'remaining')]"/>
                <group name="group_by">
                    <filter name="group_task" string="Task"
                            context="{'group_by': 'task_id'}"/>
                    <filter name="group_user" string="User"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_day" string="Day"
                            context="{'group_by': 'day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="itlingo_task_day_effort_action" model="ir.actions.act_window">
        <field name="name">Task Day Efforts</field>
        <field name="res_model">itlingo.task.day.effort</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="itlingo_task_day_effort_view_search"/>
    </record>

</odoo>
