<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_sprint_plan_backlog_view_form" model="ir.ui.view">
        <field name="name">itlingo.sprint.plan.backlog.form</field>
        <field name="model">itlingo.sprint.plan.backlog</field>
        <field name="arch" type="xml">
            <form string="Add from product backlog">
                <group>
                    <field name="sprint_id" invisible="1"/>
                    <field name="project_id" invisible="1"/>
                    <field name="item_ids" nolabel="1" options="{'no_create': True}">
                        <list>
                            <field name="identifier"/>
                            <field name="name"/>
                            <field name="item_type"/>
                            <field name="story_points"/>
                            <field name="status"/>
                            <field name="sprint_id" optional="show"/>
                        </list>
                    </field>
                </group>
                <footer>
                    <button name="action_apply" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
