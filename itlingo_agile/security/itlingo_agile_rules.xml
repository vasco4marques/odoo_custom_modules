<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- Sprint: admin sees all -->
    <record id="itlingo_sprint_rule_admin" model="ir.rule">
        <field name="name">ITLingo Sprint: admin sees all</field>
        <field name="model_id" ref="model_itlingo_sprint"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <!-- Sprint: member sees sprints in projects where they have an accepted role -->
    <record id="itlingo_sprint_rule_member" model="ir.rule">
        <field name="name">ITLingo Sprint: member sees sprints in own projects</field>
        <field name="model_id" ref="model_itlingo_sprint"/>
        <field name="domain_force">[('project_id.workspace_role_ids.user_id', '=', user.id), ('project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <!-- Sprint: portal -->
    <record id="itlingo_sprint_rule_portal" model="ir.rule">
        <field name="name">ITLingo Sprint: portal sees sprints in own projects</field>
        <field name="model_id" ref="model_itlingo_sprint"/>
        <field name="domain_force">[('project_id.workspace_role_ids.user_id', '=', user.id), ('project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Backlog Item: admin sees all -->
    <record id="itlingo_backlog_item_rule_admin" model="ir.rule">
        <field name="name">ITLingo Backlog Item: admin sees all</field>
        <field name="model_id" ref="model_itlingo_backlog_item"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <!-- Backlog Item: member sees items in own projects -->
    <record id="itlingo_backlog_item_rule_member" model="ir.rule">
        <field name="name">ITLingo Backlog Item: member sees items in own projects</field>
        <field name="model_id" ref="model_itlingo_backlog_item"/>
        <field name="domain_force">[('project_id.workspace_role_ids.user_id', '=', user.id), ('project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <!-- Backlog Item: portal -->
    <record id="itlingo_backlog_item_rule_portal" model="ir.rule">
        <field name="name">ITLingo Backlog Item: portal sees items in own projects</field>
        <field name="model_id" ref="model_itlingo_backlog_item"/>
        <field name="domain_force">[('project_id.workspace_role_ids.user_id', '=', user.id), ('project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Task Day Effort: admin sees all -->
    <record id="itlingo_task_day_effort_rule_admin" model="ir.rule">
        <field name="name">ITLingo Task Day Effort: admin sees all</field>
        <field name="model_id" ref="model_itlingo_task_day_effort"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <!-- Task Day Effort: member sees own entries -->
    <record id="itlingo_task_day_effort_rule_member" model="ir.rule">
        <field name="name">ITLingo Task Day Effort: member sees own</field>
        <field name="model_id" ref="model_itlingo_task_day_effort"/>
        <field name="domain_force">[('task_id.project_id.workspace_role_ids.user_id', '=', user.id), ('task_id.project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

</data>
</odoo>
