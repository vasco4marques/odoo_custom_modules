<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- ITLingo Admin sees all project roles -->
    <record id="itlingo_project_role_rule_admin" model="ir.rule">
        <field name="name">ITLingo Project Role: admin sees all</field>
        <field name="model_id" ref="model_itlingo_project_role"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <!-- Members see project roles in projects where they have an accepted role -->
    <record id="itlingo_project_role_rule_member" model="ir.rule">
        <field name="name">ITLingo Project Role: member sees roles in own projects</field>
        <field name="model_id" ref="model_itlingo_project_role"/>
        <field name="domain_force">[('project_id.workspace_role_ids.user_id', '=', user.id), ('project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <!-- Portal sees own project roles -->
    <record id="itlingo_project_role_rule_portal" model="ir.rule">
        <field name="name">ITLingo Project Role: portal sees own roles</field>
        <field name="model_id" ref="model_itlingo_project_role"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), '&amp;', ('project_id.workspace_role_ids.user_id', '=', user.id), ('project_id.workspace_role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

</data>
</odoo>
