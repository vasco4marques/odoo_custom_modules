<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- Demo Projects linked to organizations -->
    <record id="project_itlingo_platform" model="project.project">
        <field name="name">ITLingo Platform</field>
        <field name="organization_id" ref="itlingo_organizations.org_techcorp"/>
        <field name="methodology">scrum</field>
        <field name="business_status">executing</field>
        <field name="description">&lt;p&gt;Main platform development workspace.&lt;/p&gt;</field>
    </record>

    <record id="project_research" model="project.project">
        <field name="name">SE Research Project</field>
        <field name="organization_id" ref="itlingo_organizations.org_university"/>
        <field name="methodology">kanban</field>
        <field name="business_status">not_started</field>
        <field name="description">&lt;p&gt;Software engineering research project.&lt;/p&gt;</field>
    </record>

    <!-- Demo workspace roles -->
    <record id="role_admin_itlingo_platform" model="itlingo.project.role">
        <field name="user_id" ref="base.user_admin"/>
        <field name="project_id" ref="project_itlingo_platform"/>
        <field name="role">ws_manager</field>
        <field name="state">accepted</field>
    </record>

    <record id="role_admin_research" model="itlingo.project.role">
        <field name="user_id" ref="base.user_admin"/>
        <field name="project_id" ref="project_research"/>
        <field name="role">product_manager</field>
        <field name="state">accepted</field>
    </record>

</data>
</odoo>
