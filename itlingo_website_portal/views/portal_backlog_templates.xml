<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Backlog Page -->
    <template id="portal_backlog" name="Backlog">
        <t t-call="portal.portal_layout">
            <h3 class="mt-3">
                Product Backlog -
                <a t-attf-href="/my/workspaces/#{project.id}"><t t-out="project.name"/></a>
            </h3>
            <div class="mb-3">
                <a t-attf-href="/my/workspaces/#{project.id}" class="btn btn-outline-secondary">
                    Back to workspace
                </a>
            </div>

            <t t-if="not backlog_items">
                <div class="alert alert-info" role="alert">
                    The product backlog is empty.
                </div>
            </t>

            <t t-if="backlog_items">
                <table class="table table-sm mt-3">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Sprint</th>
                            <th>Story Points</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Tasks</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="backlog_items" t-as="item">
                            <td class="text-muted"><t t-out="item.identifier"/></td>
                            <td>
                                <a t-attf-href="/my/backlog/#{project.id}/item/#{item.id}">
                                    <t t-out="item.name"/>
                                </a>
                            </td>
                            <td><t t-out="item.item_type"/></td>
                            <td><t t-out="item.sprint_id.name or '-'"/></td>
                            <td><t t-out="item.story_points"/></td>
                            <td>
                                <span t-attf-class="badge #{
                                    item.priority == 'vhi' and 'bg-danger' or
                                    item.priority == 'hi' and 'bg-warning' or
                                    item.priority == 'med' and 'bg-info' or
                                    item.priority == 'lo' and 'bg-secondary' or 'bg-light text-dark'
                                }">
                                    <t t-out="item.priority"/>
                                </span>
                            </td>
                            <td>
                                <span t-attf-class="badge #{
                                    item.status == 'done' and 'bg-success' or
                                    item.status == 'in_progress' and 'bg-primary' or
                                    item.status == 'canceled' and 'bg-danger' or 'bg-secondary'
                                }">
                                    <t t-out="item.status"/>
                                </span>
                            </td>
                            <td><t t-out="item.task_count"/></td>
                        </tr>
                    </tbody>
                </table>
            </t>
        </t>
    </template>

    <template id="portal_backlog_item_detail" name="Backlog item">
        <t t-call="itlingo_website_portal.portal_workspace_hub_shell">
            <div class="mb-3">
                <a t-attf-href="/my/workspaces/#{project.id}/product-backlog" class="btn btn-outline-secondary btn-sm">
                    Back to backlog
                </a>
            </div>
            <h2 class="h5"><t t-out="item.name"/></h2>
            <p class="text-muted"><t t-out="item.identifier"/></p>

            <div class="card border-0 shadow-sm rounded-3 mt-3">
                <div class="card-body">
                    <t t-if="can_manage_backlog">
                        <h5 class="card-title">Update status</h5>
                        <form t-attf-action="/my/workspaces/#{project.id}/product-backlog/item/#{item.id}" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="mb-3">
                                <label class="form-label" for="status">Status</label>
                                <select class="form-select" name="status" id="status">
                                    <t t-foreach="status_selection" t-as="opt">
                                        <option t-att-value="opt[0]"
                                                t-att-selected="'selected' if opt[0] == item.status else False">
                                            <t t-out="opt[1]"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </form>
                    </t>
                    <t t-else="">
                        <h5 class="card-title">Status</h5>
                        <span class="badge bg-secondary">
                            <t t-out="dict(item._fields['status'].selection).get(item.status)"/>
                        </span>
                    </t>
                </div>
            </div>
        </t>
    </template>

</odoo>
