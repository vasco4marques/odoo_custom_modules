<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Invitations Page -->
    <template id="portal_my_invitations" name="My Invitations">
        <t t-call="portal.portal_layout">
            <h3 class="mt-3">Pending Invitations</h3>
            <div class="mb-3">
                <a href="/my" class="btn btn-outline-secondary btn-sm">Portal home</a>
                <a href="/my/organizations" class="btn btn-outline-secondary btn-sm ms-1">Organizations</a>
                <a href="/my/workspaces" class="btn btn-outline-secondary btn-sm ms-1">Workspaces</a>
            </div>

            <!-- Organization Invitations -->
            <t t-if="org_invitations">
                <h5 class="mt-4">Organization Invitations</h5>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Organization</th>
                            <th>Role</th>
                            <th>Invited</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="org_invitations" t-as="inv">
                            <td><t t-out="inv.organization_id.name"/></td>
                            <td>
                                <span class="badge bg-info">
                                    <t t-out="dict(inv._fields['role'].selection).get(inv.role)"/>
                                </span>
                            </td>
                            <td><t t-out="inv.invite_date"/></td>
                            <td>
                                <a t-attf-href="/my/invitations/org/#{inv.id}/accept"
                                   class="btn btn-sm btn-success me-1">Accept</a>
                                <a t-attf-href="/my/invitations/org/#{inv.id}/reject"
                                   class="btn btn-sm btn-danger">Reject</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </t>

            <!-- Workspace Invitations -->
            <t t-if="ws_invitations">
                <h5 class="mt-4">Workspace Invitations</h5>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Workspace</th>
                            <th>Role</th>
                            <th>Invited</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="ws_invitations" t-as="inv">
                            <td><t t-out="inv.project_id.name"/></td>
                            <td>
                                <span class="badge bg-info">
                                    <t t-out="dict(inv._fields['role'].selection).get(inv.role)"/>
                                </span>
                            </td>
                            <td><t t-out="inv.invite_date"/></td>
                            <td>
                                <a t-attf-href="/my/invitations/ws/#{inv.id}/accept"
                                   class="btn btn-sm btn-success me-1">Accept</a>
                                <a t-attf-href="/my/invitations/ws/#{inv.id}/reject"
                                   class="btn btn-sm btn-danger">Reject</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </t>

            <div t-if="not org_invitations and not ws_invitations"
                 class="alert alert-info mt-3" role="alert">
                You have no pending invitations.
            </div>
        </t>
    </template>

</odoo>
