<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="backlog_import_wizard_form" model="ir.ui.view">
        <field name="name">itlingo.backlog.import.wizard.form</field>
        <field name="model">itlingo.backlog.import.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="project_id"/>
                    <field name="sprint_id"/>
                    <field name="import_file" filename="import_filename"/>
                    <field name="import_filename" invisible="1"/>
                </group>
                <group invisible="not result_message">
                    <div class="alert alert-success">
                        <field name="result_message"/>
                    </div>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary"
                            invisible="result_message"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="backlog_import_wizard_action" model="ir.actions.act_window">
        <field name="name">Import Backlog</field>
        <field name="res_model">itlingo.backlog.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
