<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_sprint_summary_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="sprint">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Sprint Report: <t t-out="sprint.name"/></h2>
                        <div class="row mt-4">
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr><th>Project</th><td><t t-out="sprint.project_id.name"/></td></tr>
                                    <tr><th>Start Date</th><td><t t-out="sprint.start_date"/></td></tr>
                                    <tr><th>End Date</th><td><t t-out="sprint.end_date"/></td></tr>
                                    <tr><th>State</th><td><t t-out="sprint.state"/></td></tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr><th>Total Story Points</th><td><t t-out="sprint.total_story_points"/></td></tr>
                                    <tr><th>Completed Points</th><td><t t-out="sprint.completed_story_points"/></td></tr>
                                    <tr><th>Backlog Items</th><td><t t-out="sprint.backlog_item_count"/></td></tr>
                                    <tr><th>Tasks</th><td><t t-out="sprint.task_count"/></td></tr>
                                </table>
                            </div>
                        </div>

                        <t t-if="sprint.goal">
                            <h4 class="mt-4">Sprint Goal</h4>
                            <p><t t-out="sprint.goal"/></p>
                        </t>

                        <h4 class="mt-4">Backlog Items</h4>
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Points</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="sprint.backlog_item_ids" t-as="item">
                                    <tr>
                                        <td><t t-out="item.identifier"/></td>
                                        <td><t t-out="item.name"/></td>
                                        <td><t t-out="item.item_type"/></td>
                                        <td><t t-out="item.story_points"/></td>
                                        <td><t t-out="item.priority"/></td>
                                        <td><t t-out="item.status"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <h4 class="mt-4">Team Members</h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Utilization %</th>
                                    <th>Daily Hours</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="sprint.sprint_user_ids" t-as="su">
                                    <tr>
                                        <td><t t-out="su.user_id.name"/></td>
                                        <td><t t-out="su.dev_utilization"/>%</td>
                                        <td><t t-out="su.daily_work_hours"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
