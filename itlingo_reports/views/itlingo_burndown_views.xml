<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_burndown_report_view_tree" model="ir.ui.view">
        <field name="name">itlingo.burndown.report.tree</field>
        <field name="model">itlingo.burndown.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="sprint_id"/>
                <field name="project_id" string="Workspace"/>
                <field name="day"/>
                <field name="total_story_points"/>
                <field name="completed_story_points"/>
                <field name="remaining_story_points"/>
                <field name="task_count"/>
                <field name="completed_task_count"/>
            </list>
        </field>
    </record>

    <record id="itlingo_burndown_report_view_graph" model="ir.ui.view">
        <field name="name">itlingo.burndown.report.graph</field>
        <field name="model">itlingo.burndown.report</field>
        <field name="arch" type="xml">
            <graph type="line">
                <field name="day" type="row"/>
                <field name="remaining_story_points" type="measure"/>
                <field name="completed_story_points" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="itlingo_burndown_report_view_pivot" model="ir.ui.view">
        <field name="name">itlingo.burndown.report.pivot</field>
        <field name="model">itlingo.burndown.report</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="sprint_id" type="row"/>
                <field name="day" type="col" interval="day"/>
                <field name="remaining_story_points" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="itlingo_burndown_report_view_search" model="ir.ui.view">
        <field name="name">itlingo.burndown.report.search</field>
        <field name="model">itlingo.burndown.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="sprint_id"/>
                <field name="project_id"/>
                <group name="group_by">
                    <filter name="group_sprint" string="Sprint"
                            context="{'group_by': 'sprint_id'}"/>
                    <filter name="group_project" string="Workspace"
                            context="{'group_by': 'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="itlingo_burndown_report_action" model="ir.actions.act_window">
        <field name="name">Burndown Chart</field>
        <field name="res_model">itlingo.burndown.report</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="itlingo_burndown_report_view_search"/>
    </record>

</odoo>
