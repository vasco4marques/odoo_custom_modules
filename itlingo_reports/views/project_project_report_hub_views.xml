<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="project_project_view_form_itlingo_reports" model="ir.ui.view">
        <field name="name">project.project.form.itlingo.reports</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="itlingo_agile.project_project_view_form_itlingo_hub"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_burndown_report" type="object"
                        class="oe_stat_button" icon="fa-line-chart"
                        title="Burndown chart for this workspace">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Burndown</span>
                    </div>
                </button>
                <button name="action_view_velocity_report" type="object"
                        class="oe_stat_button" icon="fa-bar-chart"
                        title="Velocity for this workspace">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Velocity</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
