<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_velocity_report_view_tree" model="ir.ui.view">
        <field name="name">itlingo.velocity.report.tree</field>
        <field name="model">itlingo.velocity.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="project_id" string="Workspace"/>
                <field name="sprint_name"/>
                <field name="sprint_sequence"/>
                <field name="sprint_state" widget="badge"/>
                <field name="planned_points"/>
                <field name="completed_points"/>
                <field name="velocity_pct" widget="progressbar"/>
                <field name="sprint_duration_days"/>
            </list>
        </field>
    </record>

    <record id="itlingo_velocity_report_view_graph" model="ir.ui.view">
        <field name="name">itlingo.velocity.report.graph</field>
        <field name="model">itlingo.velocity.report</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="sprint_name" type="row"/>
                <field name="planned_points" type="measure"/>
                <field name="completed_points" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="itlingo_velocity_report_view_search" model="ir.ui.view">
        <field name="name">itlingo.velocity.report.search</field>
        <field name="model">itlingo.velocity.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="sprint_name"/>
                <field name="project_id"/>
                <group name="group_by">
                    <filter name="group_project" string="Workspace"
                            context="{'group_by': 'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="itlingo_velocity_report_action" model="ir.actions.act_window">
        <field name="name">Velocity Chart</field>
        <field name="res_model">itlingo.velocity.report</field>
        <field name="view_mode">graph,list</field>
        <field name="search_view_id" ref="itlingo_velocity_report_view_search"/>
    </record>

</odoo>
