<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_integration_token_view_tree" model="ir.ui.view">
        <field name="name">itlingo.integration.token.tree</field>
        <field name="model">itlingo.integration.token</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="project_id"/>
                <field name="description"/>
                <field name="expires_at"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="create_date" string="Created"/>
            </list>
        </field>
    </record>

    <record id="itlingo_integration_token_view_form" model="ir.ui.view">
        <field name="name">itlingo.integration.token.form</field>
        <field name="model">itlingo.integration.token</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_token" string="Generate Token"
                            type="object" class="btn-primary"
                            invisible="token_ct"/>
                    <button name="action_generate_token" string="Regenerate Token"
                            type="object" class="btn-warning"
                            invisible="not token_ct"/>
                    <button name="action_revoke" string="Revoke"
                            type="object" class="btn-danger"
                            invisible="not is_active"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="project_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="is_active"/>
                            <field name="expires_at"/>
                            <field name="create_date" string="Created"/>
                        </group>
                    </group>
                    <group invisible="not token_ct">
                        <field name="token_iv" widget="CopyClipboardText"/>
                        <field name="token_ct" widget="CopyClipboardText"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_integration_token_view_search" model="ir.ui.view">
        <field name="name">itlingo.integration.token.search</field>
        <field name="model">itlingo.integration.token</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="project_id"/>
                <filter name="active_only" string="Active"
                        domain="[('is_active', '=', True)]"/>
                <filter name="expired" string="Expired"
                        domain="[('expires_at', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
            </search>
        </field>
    </record>

    <record id="itlingo_integration_token_action" model="ir.actions.act_window">
        <field name="name">API Tokens</field>
        <field name="res_model">itlingo.integration.token</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_integration_token_view_search"/>
        <field name="context">{'search_default_active_only': 1}</field>
    </record>

</odoo>
