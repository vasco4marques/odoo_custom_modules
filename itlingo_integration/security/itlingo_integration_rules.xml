<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="1">

    <!-- Users only see their own tokens -->
    <record id="itlingo_token_rule_own" model="ir.rule">
        <field name="name">ITLingo Token: own tokens only</field>
        <field name="model_id" ref="model_itlingo_integration_token"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="itlingo_token_rule_admin" model="ir.rule">
        <field name="name">ITLingo Token: admin sees all</field>
        <field name="model_id" ref="model_itlingo_integration_token"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

</data>
</odoo>
