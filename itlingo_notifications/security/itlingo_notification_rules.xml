<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- Users only see their own notifications -->
    <record id="itlingo_notification_rule_own" model="ir.rule">
        <field name="name">ITLingo Notification: own only</field>
        <field name="model_id" ref="model_itlingo_notification"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
    </record>

    <record id="itlingo_notification_rule_admin" model="ir.rule">
        <field name="name">ITLingo Notification: admin sees all</field>
        <field name="model_id" ref="model_itlingo_notification"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <!-- Users see messages where they are sender or recipient -->
    <record id="itlingo_message_rule_own" model="ir.rule">
        <field name="name">ITLingo Message: own only</field>
        <field name="model_id" ref="model_itlingo_message"/>
        <field name="domain_force">['|', ('sender_id', '=', user.id), ('recipient_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user')), (4, ref('base.group_portal'))]"/>
    </record>

    <record id="itlingo_message_rule_admin" model="ir.rule">
        <field name="name">ITLingo Message: admin sees all</field>
        <field name="model_id" ref="model_itlingo_message"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

</data>
</odoo>
