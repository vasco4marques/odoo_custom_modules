<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_notification_view_tree" model="ir.ui.view">
        <field name="name">itlingo.notification.tree</field>
        <field name="model">itlingo.notification</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date" string="Date"/>
                <field name="user_id"/>
                <field name="notification_type" widget="badge"/>
                <field name="title"/>
                <field name="is_read" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="itlingo_notification_view_form" model="ir.ui.view">
        <field name="name">itlingo.notification.form</field>
        <field name="model">itlingo.notification</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_read" string="Mark as Read"
                            type="object" class="btn-primary"
                            invisible="is_read"/>
                    <button name="action_mark_unread" string="Mark Unread"
                            type="object"
                            invisible="not is_read"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="notification_type"/>
                            <field name="title"/>
                        </group>
                        <group>
                            <field name="is_read"/>
                            <field name="read_date"/>
                            <field name="create_date" string="Sent At"/>
                        </group>
                    </group>
                    <group>
                        <field name="body"/>
                    </group>
                    <group>
                        <field name="res_model"/>
                        <field name="res_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_notification_view_search" model="ir.ui.view">
        <field name="name">itlingo.notification.search</field>
        <field name="model">itlingo.notification</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <field name="user_id"/>
                <filter name="unread" string="Unread"
                        domain="[('is_read', '=', False)]"/>
                <filter name="read" string="Read"
                        domain="[('is_read', '=', True)]"/>
                <separator/>
                <group name="group_by">
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'notification_type'}"/>
                    <filter name="group_user" string="Recipient"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="itlingo_notification_action" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">itlingo.notification</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_notification_view_search"/>
        <field name="context">{'search_default_unread': 1}</field>
    </record>

</odoo>
