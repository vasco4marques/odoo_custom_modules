<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_message_view_tree" model="ir.ui.view">
        <field name="name">itlingo.message.tree</field>
        <field name="model">itlingo.message</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date" string="Date"/>
                <field name="sender_id"/>
                <field name="recipient_id"/>
                <field name="subject"/>
                <field name="is_read" widget="boolean_toggle"/>
                <field name="project_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="itlingo_message_view_form" model="ir.ui.view">
        <field name="name">itlingo.message.form</field>
        <field name="model">itlingo.message</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_read" string="Mark as Read"
                            type="object" class="btn-primary"
                            invisible="is_read"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="sender_id"/>
                            <field name="recipient_id"/>
                            <field name="subject"/>
                        </group>
                        <group>
                            <field name="is_read"/>
                            <field name="read_date"/>
                            <field name="project_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="body"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="itlingo_message_view_search" model="ir.ui.view">
        <field name="name">itlingo.message.search</field>
        <field name="model">itlingo.message</field>
        <field name="arch" type="xml">
            <search>
                <field name="subject"/>
                <field name="sender_id"/>
                <field name="recipient_id"/>
                <filter name="unread" string="Unread"
                        domain="[('is_read', '=', False)]"/>
                <filter name="inbox" string="My Inbox"
                        domain="[('recipient_id', '=', uid)]"/>
                <filter name="sent" string="Sent"
                        domain="[('sender_id', '=', uid)]"/>
            </search>
        </field>
    </record>

    <record id="itlingo_message_action" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">itlingo.message</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itlingo_message_view_search"/>
        <field name="context">{'search_default_inbox': 1}</field>
    </record>

</odoo>
