<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal home cards -->
    <template id="portal_my_home_notifications"
              name="Portal Notifications"
              inherit_id="portal.portal_my_home"
              priority="65">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/itlingo_notifications/static/description/icon.png'"/>
                <t t-set="title">Notifications</t>
                <t t-set="url" t-value="'/my/notifications'"/>
                <t t-set="text">View your notifications</t>
                <t t-set="count" t-value="notification_count"/>
                <t t-set="placeholder_count" t-value="'notification_count'"/>
            </t>
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/itlingo_notifications/static/description/icon.png'"/>
                <t t-set="title">Messages</t>
                <t t-set="url" t-value="'/my/messages'"/>
                <t t-set="text">Your direct messages</t>
                <t t-set="count" t-value="message_count"/>
                <t t-set="placeholder_count" t-value="'message_count'"/>
            </t>
        </xpath>
    </template>

    <!-- Notification list -->
    <template id="portal_my_notifications" name="My Notifications">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Notifications</t>
            </t>

            <div class="mb-3 text-end">
                <a href="/my/notifications/mark_all_read" class="btn btn-sm btn-outline-primary">
                    <i class="fa fa-check-double"/> Mark all as read
                </a>
            </div>

            <t t-if="not notifications">
                <div class="alert alert-info">No notifications.</div>
            </t>
            <t t-if="notifications">
                <div class="list-group">
                    <t t-foreach="notifications" t-as="notif">
                        <div t-attf-class="list-group-item #{'fw-bold' if not notif.is_read else ''}">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span t-attf-class="badge rounded-pill me-2
                                        #{'text-bg-info' if notif.notification_type == 'invite'
                                          else 'text-bg-warning' if notif.notification_type == 'status_change'
                                          else 'text-bg-primary' if notif.notification_type == 'assignment'
                                          else 'text-bg-secondary'}">
                                        <t t-out="notif.notification_type"/>
                                    </span>
                                    <t t-out="notif.title"/>
                                </div>
                                <small class="text-muted">
                                    <t t-out="notif.create_date" t-options='{"widget": "datetime"}'/>
                                </small>
                            </div>
                            <div class="mt-1 text-muted small" t-if="notif.body">
                                <t t-out="notif.body"/>
                            </div>
                        </div>
                    </t>
                </div>
                <div t-if="pager" class="o_portal_pager text-center mt-3">
                    <t t-call="portal.pager"/>
                </div>
            </t>
        </t>
    </template>

    <!-- Message list -->
    <template id="portal_my_messages" name="My Messages">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Messages</t>
            </t>

            <t t-if="not messages">
                <div class="alert alert-info">No messages.</div>
            </t>
            <t t-if="messages">
                <div class="list-group">
                    <t t-foreach="messages" t-as="msg">
                        <div t-attf-class="list-group-item #{'fw-bold' if not msg.is_read and msg.recipient_id.id == request.uid else ''}">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <span class="text-muted small me-2">
                                        <t t-if="msg.sender_id.id == request.uid">
                                            To: <t t-out="msg.recipient_id.name"/>
                                        </t>
                                        <t t-else="">
                                            From: <t t-out="msg.sender_id.name"/>
                                        </t>
                                    </span>
                                    <strong t-if="msg.subject"><t t-out="msg.subject"/></strong>
                                </div>
                                <small class="text-muted">
                                    <t t-out="msg.create_date" t-options='{"widget": "datetime"}'/>
                                </small>
                            </div>
                            <div class="mt-1" t-if="msg.body">
                                <t t-out="msg.body"/>
                            </div>
                        </div>
                    </t>
                </div>
                <div t-if="pager" class="o_portal_pager text-center mt-3">
                    <t t-call="portal.pager"/>
                </div>
            </t>
        </t>
    </template>

</odoo>
