<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <!-- DSL metadata: non-admin users see active DSLs plus DSLs they maintain. -->
    <record id="itlingo_dsl_rule_admin" model="ir.rule">
        <field name="name">ITLingo DSL: admin sees all</field>
        <field name="model_id" ref="model_itlingo_dsl"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <record id="itlingo_dsl_rule_manager" model="ir.rule">
        <field name="name">ITLingo DSL: manager sees active or maintained</field>
        <field name="model_id" ref="model_itlingo_dsl"/>
        <field name="domain_force">['|', ('status', '=', 'active'), ('maintainer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_manager'))]"/>
    </record>

    <record id="itlingo_dsl_rule_member" model="ir.rule">
        <field name="name">ITLingo DSL: member sees active or maintained</field>
        <field name="model_id" ref="model_itlingo_dsl"/>
        <field name="domain_force">['|', ('status', '=', 'active'), ('maintainer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <record id="itlingo_dsl_rule_portal" model="ir.rule">
        <field name="name">ITLingo DSL: portal sees active or maintained</field>
        <field name="model_id" ref="model_itlingo_dsl"/>
        <field name="domain_force">['|', ('status', '=', 'active'), ('maintainer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Definition files are private to admins and assigned maintainers. -->
    <record id="itlingo_dsl_file_rule_admin" model="ir.rule">
        <field name="name">ITLingo DSL File: admin sees all</field>
        <field name="model_id" ref="model_itlingo_dsl_file"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <record id="itlingo_dsl_file_rule_manager" model="ir.rule">
        <field name="name">ITLingo DSL File: manager sees maintained DSL files</field>
        <field name="model_id" ref="model_itlingo_dsl_file"/>
        <field name="domain_force">[('dsl_id.maintainer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_manager'))]"/>
    </record>

    <record id="itlingo_dsl_file_rule_member" model="ir.rule">
        <field name="name">ITLingo DSL File: member sees maintained DSL files</field>
        <field name="model_id" ref="model_itlingo_dsl_file"/>
        <field name="domain_force">[('dsl_id.maintainer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <record id="itlingo_dsl_file_rule_portal" model="ir.rule">
        <field name="name">ITLingo DSL File: portal sees maintained DSL files</field>
        <field name="model_id" ref="model_itlingo_dsl_file"/>
        <field name="domain_force">[('dsl_id.maintainer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Admins see and manage all organization resources -->
    <record id="itlingo_org_resource_rule_admin" model="ir.rule">
        <field name="name">ITLingo Org Resource: admin sees all</field>
        <field name="model_id" ref="model_itlingo_org_resource"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_admin'))]"/>
    </record>

    <!-- Members: public resources, or resources of organizations they belong to -->
    <record id="itlingo_org_resource_rule_member" model="ir.rule">
        <field name="name">ITLingo Org Resource: member sees public or own org</field>
        <field name="model_id" ref="model_itlingo_org_resource"/>
        <field name="domain_force">['|', ('visibility', '=', 'public'), '&amp;', ('organization_id.role_ids.user_id', '=', user.id), ('organization_id.role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('itlingo_organizations.group_itlingo_member'))]"/>
    </record>

    <!-- Portal users: public resources, or resources of organizations they belong to -->
    <record id="itlingo_org_resource_rule_portal" model="ir.rule">
        <field name="name">ITLingo Org Resource: portal sees public or own org</field>
        <field name="model_id" ref="model_itlingo_org_resource"/>
        <field name="domain_force">['|', ('visibility', '=', 'public'), '&amp;', ('organization_id.role_ids.user_id', '=', user.id), ('organization_id.role_ids.state', '=', 'accepted')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
    </record>

</data>
</odoo>
