<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_itlingo_dsl_list" model="ir.ui.view">
        <field name="name">itlingo.dsl.list</field>
        <field name="model">itlingo.dsl</field>
        <field name="arch" type="xml">
            <list string="DSLs">
                <field name="name"/>
                <field name="acronym"/>
                <field name="version"/>
                <field name="status" widget="badge"
                       decoration-info="status == 'draft'"
                       decoration-success="status == 'active'"
                       decoration-warning="status == 'deprecated'"/>
                <field name="file_extensions"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_itlingo_dsl_form" model="ir.ui.view">
        <field name="name">itlingo.dsl.form</field>
        <field name="model">itlingo.dsl</field>
        <field name="arch" type="xml">
            <form string="DSL">
                <header>
                    <button name="action_publish" type="object"
                            string="Publish" class="btn-primary"
                            invisible="status == 'active' or not id"
                            confirm="Publishing validates the grammar server-side, deprecates any previously active version of this acronym, and refreshes the chatbot knowledge base. It does not build or deploy templating/ITOI parsers, which remain separately deployed. Continue?"/>
                    <button name="action_create_draft_version_ui" type="object"
                            string="Create Draft Version"
                            invisible="status == 'draft' or not id"
                            help="Copies this DSL's metadata and definition files into a new editable draft version without modifying this version."/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,active,deprecated"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Requirements Specification Language"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Main Information">
                            <field name="acronym"/>
                            <field name="version"/>
                            <field name="status"/>
                        </group>
                        <group string="Technical References">
                            <field name="file_extensions"/>
                            <field name="grammar_reference" widget="url"/>
                            <field name="parser_validator_reference" widget="url"/>
                            <field name="documentation_url" widget="url"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Definition Files">
                            <p class="text-muted">
                                Files that define this DSL and are pushed to the
                                chatbot knowledge base when the DSL is Active.
                                Grammar and services workspaces may contain
                                multiple files and must identify exactly one
                                entry file per type.
                                Validation and Examples files are concatenated;
                                Specifications are kept as separate files.
                            </p>
                            <field name="file_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="file_type"/>
                                    <field name="file" filename="file_name"/>
                                    <field name="file_name"/>
                                    <field name="relative_path"
                                           invisible="file_type not in ['grammar', 'services']"/>
                                    <field name="is_entry"
                                           invisible="file_type not in ['grammar', 'services']"/>
                                    <field name="is_enabled"/>
                                </list>
                            </field>
                        </page>
                        <page string="Maintainers">
                            <field name="maintainer_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Publication">
                            <group>
                                <group string="Grammar Validation">
                                    <field name="grammar_validation_result"/>
                                    <field name="grammar_validation_is_current"/>
                                    <field name="grammar_validation_time"/>
                                    <field name="grammar_validator_version"/>
                                </group>
                                <group string="Services Compilation">
                                    <field name="services_compile_result"/>
                                    <field name="services_compile_time"/>
                                    <field name="services_source_digest"/>
                                    <field name="services_compiled_digest"/>
                                </group>
                                <group string="Publication Audit">
                                    <field name="published_by_id"/>
                                    <field name="published_at"/>
                                    <field name="published_digest"/>
                                    <field name="grammar_validation_digest"/>
                                </group>
                            </group>
                            <group>
                                <field name="grammar_validation_diagnostics" readonly="1"/>
                                <field name="services_compile_diagnostics" readonly="1"/>
                            </group>
                            <p class="text-muted">
                                Publishing validates the grammar with the bundled
                                Langium validator, compiles any services TypeScript
                                workspace, and refreshes the chatbot knowledge base.
                                It does not build or deploy the templating or ITOI
                                parsers, which are deployed separately.
                            </p>
                        </page>
                        <page string="Administration">
                            <group>
                                <field name="notes"/>
                                <field name="active"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_itlingo_dsl_search" model="ir.ui.view">
        <field name="name">itlingo.dsl.search</field>
        <field name="model">itlingo.dsl</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="acronym"/>
                <field name="version"/>
                <field name="description"/>
                <filter string="Active" name="active_status"
                        domain="[('status', '=', 'active')]"/>
                <filter string="Draft" name="draft_status"
                        domain="[('status', '=', 'draft')]"/>
                <filter string="Deprecated" name="deprecated_status"
                        domain="[('status', '=', 'deprecated')]"/>
                <filter string="Archived (Inactive)" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group name="group_by">
                    <filter string="Status" name="group_by_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Acronym" name="group_by_acronym"
                            context="{'group_by': 'acronym'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_itlingo_dsl" model="ir.actions.act_window">
        <field name="name">DSLs</field>
        <field name="res_model">itlingo.dsl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_itlingo_dsl_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new platform DSL
            </p>
            <p>
                Each DSL is defined once at platform level and referenced
                across organizations and workspaces.
            </p>
        </field>
    </record>

</odoo>
