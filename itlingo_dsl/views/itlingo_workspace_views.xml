<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="itlingo_workspace_view_form_inherit_dsl" model="ir.ui.view">
        <field name="name">itlingo.workspace.form.inherit.dsl</field>
        <field name="model">itlingo.workspace</field>
        <field name="inherit_id" ref="itlingo_workspace_access.itlingo_workspace_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='itlingo_workspace']/separator" position="before">
                <separator string="DSLs"/>
                <group>
                    <group string="DSL Availability">
                        <field name="allowed_dsl_ids" widget="many2many_tags"
                               options="{'no_create': True, 'no_create_edit': True}"
                               placeholder="Leave empty to inherit organization DSLs"/>
                        <field name="default_dsl_id"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
